{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "forge/vision.schema.json",
  "title": "Forge Vision Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["vision"],
  "properties": {
    "vision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "mission",
        "core_purpose",
        "key_architecture",
        "long_term_vision",
        "key_principles",
        "market_strategy",
        "last_validated"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "mission": {
          "type": "string",
          "minLength": 1,
          "maxLength": 400
        },
        "core_purpose": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "key_architecture": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "last_validated": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "long_term_vision": {
          "type": "object",
          "additionalProperties": false,
          "required": ["strategic_goals"],
          "properties": {
            "strategic_goals": {
              "type": "object",
              "additionalProperties": false,
              "required": ["now", "next", "later"],
              "properties": {
                "now": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 280
                },
                "next": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 280
                },
                "later": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 280
                }
              }
            }
          }
        },
        "key_principles": {
          "type": "array",
          "minItems": 1,
          "maxItems": 7,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 180
          }
        },
        "market_strategy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "competitive_advantages",
            "differentiation_from_competitors"
          ],
          "properties": {
            "competitive_advantages": {
              "type": "array",
              "minItems": 1,
              "maxItems": 7,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 180
              }
            },
            "differentiation_from_competitors": {
              "type": "array",
              "minItems": 1,
              "maxItems": 7,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 180
              }
            }
          }
        }
      }
    }
  }
}
