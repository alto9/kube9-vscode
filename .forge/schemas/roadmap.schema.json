{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "forge/roadmap.schema.json",
  "title": "Forge Roadmap Schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["roadmap"],
  "properties": {
    "roadmap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["milestones"],
      "properties": {
        "milestones": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/milestone"
          }
        }
      }
    }
  },
  "$defs": {
    "milestone": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "outcome",
        "in_scope",
        "due_date",
        "depends_on",
        "technical_concepts",
        "tickets"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "outcome": {
          "type": "string",
          "minLength": 1,
          "maxLength": 280
        },
        "in_scope": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "due_date": {
          "type": "string",
          "pattern": "^$|^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "depends_on": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "technical_concepts": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "tickets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ticket"
          }
        }
      }
    },
    "ticket": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "description"],
      "properties": {
        "id": {
          "type": "integer"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        }
      }
    }
  }
}
